# ======================================================================
# Audio Research Assistant - environment configuration TEMPLATE
# Copy to ".env" and fill in your own values:   cp .env.example .env
# The real .env is gitignored and must never be committed.
# ======================================================================

# --- Oracle vector database ---
ORACLE_USER=AUDIO_RAG
ORACLE_PASSWORD=change_me
ORACLE_DSN=localhost:1521/FREEPDB1

# --- Chat model: ollama (local) or openrouter (cloud gateway) ---
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b-instruct

# OpenRouter (OpenAI-compatible) — ONE sk-or-v1-... key for DeepSeek, Qwen, GPT,
# Claude and 300+ models. No per-provider billing; has ":free" model slugs.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# --- Embedding & re-ranking models ---
# EMBEDDING_PROVIDER: google (Gemini API) or local (sentence-transformers)
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-2          # local example: BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3        # reranker stays local
EMBEDDING_DIM=768
# Free Gemini API key for embeddings: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Knowledge source -------------------------------------------------------
# Web search is the PRIMARY source and is production-friendly (no database).
# The local Oracle/PDF RAG is OPTIONAL — keep it off for a web-only deploy
# (then the app needs no Oracle and no uploaded papers). Turn it on only if you
# want to also search your own indexed PDFs.
ENABLE_LOCAL_RAG=false
# If you enable local cross-encoder re-ranking of external sources (loads torch):
# EXTERNAL_RERANK_CROSS_ENCODER=false

# --- External search (AUTOMATIC fallback) -----------------------------------
# On by default. There is NO toggle: when the local papers don't answer a
# question (or local RAG is off), the assistant automatically searches web pages,
# research papers (arXiv), patents, and GitHub repos/code, then answers with
# citations. Set false to disable external search entirely.
ENABLE_WEB_SEARCH=true
# arXiv (research papers) and GitHub (repos/code) are FREE and need no key.
# A web search key additionally unlocks web pages + patents:
WEB_SEARCH_PROVIDER=tavily          # tavily | brave | serpapi
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
# Optional: a GitHub token raises API limits and enables code search.
GITHUB_TOKEN=
# Accuracy/depth knobs (defaults favor accuracy over brevity):
# EVIDENCE_CHARS_PER_SOURCE=3500   # how much of each source the model reads
# EXTERNAL_TOP_K=15                # how many external sources to keep
# ANSWER_MAX_TOKENS=4096           # room for full code / simulations
# ARXIV_READ_PDF_COUNT=3           # read this many papers' full PDFs (not just abstracts)
# WEB_MAX_RESULTS=8 · ARXIV_MAX_RESULTS=6 · GITHUB_MAX_REPOS=5
# Safety / limits (sensible defaults; override only if needed)
# EXTERNAL_HTTP_TIMEOUT=12
# EXTERNAL_MAX_BYTES=3000000
# EXTERNAL_CACHE_TTL=86400
# GITHUB_MAX_REPOS=3
# GITHUB_MAX_FILES=3
# ONLINE_PDF_MAX_PAGES=30

# --- Compute device (GPU / CPU) ---
# DEVICE: auto (GPU if available, else CPU) | cuda | cpu
# Per-model overrides let you use BOTH GPU and CPU on a small GPU:
#   embeddings on GPU, the heavier reranker on CPU.
# Embeddings use the Gemini API, so the GPU is free for the reranker + Docling.
DEVICE=cuda
EMBEDDING_DEVICE=cuda
RERANKER_DEVICE=cuda

# --- Answer engine ---
ANSWER_PROVIDER=manual
APP_MODE=balanced
AUTO_INGEST=true
DEBUG_MODE=false

# --- Retrieval tuning ---
MAX_QUERY_ROUTES=4
RETRIEVAL_TOP_K=8
TOTAL_SOURCE_LIMIT=14
PER_TOPIC_SOURCE_LIMIT=3

# --- HuggingFace / tokenizer noise suppression ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_DISABLE_PROGRESS_BARS=1
HF_HUB_DISABLE_TELEMETRY=1
TRANSFORMERS_VERBOSITY=error
TOKENIZERS_PARALLELISM=false

# --- PDF parsing / ingestion ---
# Parser is Docling (best quality) with PyMuPDF fallback; OCR for scanned PDFs.
ENABLE_OCR=true
ENABLE_TABLE_EXTRACTION=true
ENABLE_EQUATION_CHUNKING=true
CHUNK_MAX_CHARS=1800
CHUNK_OVERLAP_SENTENCES=2
