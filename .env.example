# ======================================================================
# Audio Research Assistant - environment configuration TEMPLATE
# Copy to ".env" and fill in your own values:   cp .env.example .env
# The real .env is gitignored and must never be committed.
# ======================================================================

# --- Multi-user login (optional) --------------------------------------------
# ENABLE_AUTH=true  -> members sign in at /login with a user_id + password, and
#   each member's conversations are private. Create accounts with:
#       python -m backend.auth.users add <user_id>
# ENABLE_AUTH=false (default) -> open app, single shared user (original behaviour).
ENABLE_AUTH=false
# Signs the session cookie. MUST be a long random string in production (else logins
# reset on restart). Generate one: python -c "import secrets;print(secrets.token_hex(32))"
AUTH_SECRET_KEY=
# Allow visitors to self-register at /login. Off by default (admins create accounts).
ENABLE_SIGNUP=false
# Session length. Empty = a session cookie that clears when the browser closes, so
# users sign in again each visit (most secure). Set a number of seconds to stay
# logged in for that long, e.g. SESSION_MAX_AGE=604800 for one week.
SESSION_MAX_AGE=

# --- Oracle vector database ---
ORACLE_USER=AUDIO_RAG
ORACLE_PASSWORD=change_me
ORACLE_DSN=localhost:1521/FREEPDB1

# --- Chat model: OpenAI ---
# Your OpenAI API key (sk-...). Get one at https://platform.openai.com/api-keys
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5                 # e.g. gpt-5.5-pro, gpt-5.4, gpt-4.1, gpt-4o
# OPENAI_BASE_URL=                   # only for Azure OpenAI / an OpenAI-compatible proxy

# --- Embedding & re-ranking models ---
# EMBEDDING_PROVIDER: google (Gemini API) or local (sentence-transformers)
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-2          # local example: BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3        # reranker stays local
EMBEDDING_DIM=768
# Free Gemini API key for embeddings: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Knowledge source -------------------------------------------------------
# Web search is the PRIMARY source and is production-friendly (no database).
# The local Oracle/PDF RAG is OPTIONAL — keep it off for a web-only deploy
# (then the app needs no Oracle and no uploaded papers). Turn it on only if you
# want to also search your own indexed PDFs.
ENABLE_LOCAL_RAG=false
# If you enable local cross-encoder re-ranking of external sources (loads torch):
# EXTERNAL_RERANK_CROSS_ENCODER=false

# --- Optional Memgraph GraphRAG over your local PDFs -------------------------
# Adds relationship-aware expansion across Paper -> Chunk -> Concept / Section.
# Oracle remains the source of truth; Memgraph only returns related Oracle chunk IDs.
# Requires ENABLE_LOCAL_RAG=true and a running Memgraph server:
#   docker run -p 7687:7687 -p 7444:7444 --name memgraph memgraph/memgraph-mage
#   python -m backend.graph_rag.build_graph
ENABLE_GRAPH_RAG=false
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=
GRAPH_RAG_MAX_HOPS=2
GRAPH_RAG_MAX_RESULTS=12
GRAPH_RAG_TIMEOUT_SECONDS=3

# --- External search (AUTOMATIC, searches everywhere) -----------------------
# On by default, no toggle. When the local papers don't answer (or local RAG is
# off), the assistant automatically searches MANY sources and answers with
# citations: web (DuckDuckGo), research papers (arXiv + Semantic Scholar),
# Wikipedia, patents (Google Patents), and GitHub repos/code.
# EVERYTHING WORKS WITH NO API KEY. Set false to disable external search entirely.
ENABLE_WEB_SEARCH=true
# Web provider: duckduckgo (free, default) | tavily | brave | serpapi.
# A paid key gives higher-quality web results, but is not required.
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
# Optional: a GitHub token raises API limits and enables code search.
GITHUB_TOKEN=
# DANGER: disables the SSRF guard (allows fetching localhost / private / internal
# addresses). It does NOT add any public-search reach. Keep false; only true on a
# trusted single-user machine, NEVER on a public/shared deployment.
EXTERNAL_ALLOW_UNSAFE_URLS=false
# Accuracy/depth knobs (defaults favor accuracy over brevity):
# EVIDENCE_CHARS_PER_SOURCE=3500   # how much of each source the model reads
# EXTERNAL_TOP_K=20                # how many external sources to keep
# ANSWER_MAX_TOKENS=4096           # room for full code / simulations
# ARXIV_READ_PDF_COUNT=3           # read this many papers' full PDFs (not just abstracts)
# WEB_MAX_RESULTS=8 · ARXIV_MAX_RESULTS=6 · GITHUB_MAX_REPOS=5
# Agentic answer loop in the web chat: draft -> verify -> search again/refine.
ENABLE_AGENTIC_ANSWER_LOOP=true
AGENTIC_MAX_VERIFY_ROUNDS=2       # max hidden draft/verify/refine rounds per answer
AGENTIC_MIN_VERIFY_SCORE=80       # verifier score required to stop early
AGENTIC_EXTRA_SEARCH_K=8          # extra sources to gather when verifier finds gaps
AGENTIC_SIMULATE_CODE=true        # run fenced Python answers in Docker when possible
AGENTIC_SIMULATION_TIMEOUT=30     # seconds for a generated simulation/code block
# Safety / limits (sensible defaults; override only if needed)
# EXTERNAL_HTTP_TIMEOUT=12
# EXTERNAL_MAX_BYTES=3000000
# EXTERNAL_CACHE_TTL=86400
# GITHUB_MAX_REPOS=3
# GITHUB_MAX_FILES=3
# ONLINE_PDF_MAX_PAGES=30

# --- Autonomous research agent (writes code, runs it in Docker, verifies) --------
# `python -m backend.agent "your task"` — needs Docker running + OPENAI_API_KEY.
# The agent runs AI-written code in a throwaway, network-less container.
AGENT_MAX_ITERS=4              # max THINK -> RUN -> REFLECT cycles
AGENT_DOCKER_IMAGE=python:3.11-slim   # sandbox image (stdlib only by default)
AGENT_RUN_TIMEOUT=30          # seconds a single program may run
AGENT_MEM_LIMIT=512m          # container memory cap
AGENT_CPUS=1.0                # container CPU cap
# Two-tier memory keeps the agent's context constant-size across many cycles:
AGENT_BRIEF_MAX_CHARS=3000    # Tier 1: frozen brief (goal + decision tree) cap
AGENT_LOG_MAX_CHARS=2000      # Tier 2: rolling attempt-log cap (auto-compacts)
AGENT_LOG_KEEP_LAST=12        # Tier 2: also keep at most this many recent entries
# Pre-execution lifecycle hook (kimi-code idea): audit every program + a gate.
AGENT_AUDIT_LOG=data/logs/agent_audit.jsonl   # JSONL audit of each run (empty = off)
AGENT_BLOCK_PATTERNS=         # comma-separated regexes; a match blocks the run (default off)
AGENT_PRERUN_HOOK=            # a shell command; code piped to stdin; non-zero exit blocks (default off)

# --- Compute device (GPU / CPU) ---
# DEVICE: auto (GPU if available, else CPU) | cuda | cpu
# Per-model overrides let you use BOTH GPU and CPU on a small GPU:
#   embeddings on GPU, the heavier reranker on CPU.
# Embeddings use the Gemini API, so the GPU is free for the reranker + Docling.
DEVICE=cuda
EMBEDDING_DEVICE=cuda
RERANKER_DEVICE=cuda

# --- Answer engine ---
ANSWER_PROVIDER=manual
APP_MODE=balanced
AUTO_INGEST=true
DEBUG_MODE=false

# --- Retrieval tuning ---
MAX_QUERY_ROUTES=4
RETRIEVAL_TOP_K=8
TOTAL_SOURCE_LIMIT=14
PER_TOPIC_SOURCE_LIMIT=3

# --- HuggingFace / tokenizer noise suppression ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_DISABLE_PROGRESS_BARS=1
HF_HUB_DISABLE_TELEMETRY=1
TRANSFORMERS_VERBOSITY=error
TOKENIZERS_PARALLELISM=false

# --- PDF parsing / ingestion ---
# Parser is Docling (best quality) with PyMuPDF fallback; OCR for scanned PDFs.
ENABLE_OCR=true
ENABLE_TABLE_EXTRACTION=true
ENABLE_EQUATION_CHUNKING=true
CHUNK_MAX_CHARS=1800
CHUNK_OVERLAP_SENTENCES=2
