# ==============================================================================
# Audio Research Assistant - environment template
# Copy to ".env" and add your private values.
#
# Keep the real .env private. It is gitignored and must never be committed.
# ==============================================================================


# ==============================================================================
# 01. App Runtime
# ==============================================================================

DEBUG_MODE=false


# ==============================================================================
# 02. Auth
# ==============================================================================

# false = local single-user mode. true = require /login.
ENABLE_AUTH=false

# Required for stable login sessions when ENABLE_AUTH=true.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=

# true = visitors may self-register at /login.
ENABLE_SIGNUP=false

# Empty = browser-session cookie. Example one week: 604800
SESSION_MAX_AGE=

# Optional custom auth DB path.
# AUTH_DB_PATH=data/auth.db


# ==============================================================================
# 03. Database / Local PDF RAG
# ==============================================================================

ORACLE_USER=AUDIO_RAG
ORACLE_PASSWORD=change_me
ORACLE_DSN=localhost:1521/FREEPDB1

# false = web-only mode. true = also search indexed local PDFs in Oracle.
ENABLE_LOCAL_RAG=false

# Dense-vector backend for local PDFs:
# oracle    = exact Oracle VECTOR search (default, safest)
# turbovec  = compressed local accelerator; Oracle still stores text/metadata
VECTOR_BACKEND=oracle
TURBOVEC_ENABLED=false
TURBOVEC_AUTOBUILD=true
TURBOVEC_BUILD_IN_PIPELINE=false
TURBOVEC_INDEX_PATH=data/vector_cache/chunks.tvim
TURBOVEC_BIT_WIDTH=4
TURBOVEC_OVERFETCH=3
TURBOVEC_STRICT=false
TURBOVEC_BUILD_BATCH=4096


# ==============================================================================
# 04. Chat LLM
# ==============================================================================

# Two models only: "Gemini · gemini-2.5-flash" (free) and "OpenAI · gpt-5.5".
# Active selection (the Model dropdown rewrites these 3 lines):
OPENAI_API_KEY=                      # the active model's key (dropdown sets this)
OPENAI_MODEL=gemini-2.5-flash        # or: gpt-5.5
# OPENAI_BASE_URL=                   # dropdown sets this (Gemini endpoint, or blank for OpenAI)
#
# Keys:
OPENAI_CLOUD_KEY=                    # your ChatGPT/OpenAI key, for the "gpt-5.5" option
# Gemini (gemini-2.5-flash, FREE) reuses GEMINI_API_KEY from section 05 below — no extra
# key needed. Get one at https://aistudio.google.com/apikey


# ==============================================================================
# 05. Embeddings / Reranking
# ==============================================================================

# Used for Gemini embeddings (free tier). Not a chat model.
GEMINI_API_KEY=

# google = Gemini API embeddings. local = sentence-transformers.
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=768
EMBED_CONCURRENCY=6

RERANKER_MODEL=BAAI/bge-reranker-v2-m3


# ==============================================================================
# 06. External Search
# ==============================================================================

ENABLE_WEB_SEARCH=true

# duckduckgo works without a key. tavily/brave/serpapi can be better for web.
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=

# Optional: raises GitHub limits and enables code search.
GITHUB_TOKEN=
GITHUB_REPO_SORT=updated

# Keep false for shared/public deployments. true allows localhost/private URLs.
EXTERNAL_ALLOW_UNSAFE_URLS=false


# ==============================================================================
# 07. Answer Quality / Agentic Verification
# ==============================================================================

EVIDENCE_CHARS_PER_SOURCE=3500
SOURCE_MIN_SCORE=0.30
SOURCE_MIN=3
SOURCE_MAX=12
EXTERNAL_TOP_K=20
ANSWER_MAX_TOKENS=8000

ENABLE_AGENTIC_ANSWER_LOOP=true
AGENTIC_MAX_VERIFY_ROUNDS=3
AGENTIC_MIN_VERIFY_SCORE=80
AGENTIC_EXTRA_SEARCH_K=8
AGENTIC_SIMULATE_CODE=true
AGENTIC_SIMULATION_TIMEOUT=30
AGENTIC_VERIFY_MAX_TOKENS=1200

# Reuse saved answers for the same/very-similar question to avoid repeat search +
# LLM cost. Matching is lexical (near-exact) OR semantic (embeddings), and a guard
# blocks swaps/identifier changes ("A vs B" != "B vs A", "A100" != "H100") so a
# different question is never served a wrong cached answer. Freshness-sensitive
# questions ("latest", "2026", "state of the art", ...) always re-search. The cache
# is auto-cleared when you ingest/delete local PDFs.
ENABLE_ANSWER_CACHE=true
ANSWER_CACHE_MIN_SIMILARITY=0.97      # lexical bar (keep high; >=0.92 enforced)
ENABLE_ANSWER_CACHE_SEMANTIC=true    # embedding match for paraphrases (uses GEMINI_API_KEY)
ANSWER_CACHE_MIN_SEMANTIC=0.88       # cosine bar for a semantic match
ANSWER_CACHE_MAX_AGE_DAYS=30
ANSWER_CACHE_CANDIDATE_LIMIT=200
ANSWER_CACHE_ALLOW_FRESHNESS_QUERIES=false
# Automatically peer-review the final answer/code (the "Review" step, run for you):
# critique it, improve once if weak, show the verdict. One extra LLM call — set false
# to skip on slow local models.
AUTO_REVIEW=true


# ==============================================================================
# 08. External Search Limits
# ==============================================================================

EXTERNAL_HTTP_TIMEOUT=12
EXTERNAL_MAX_BYTES=3000000
EXTERNAL_MAX_RETRIES=2
EXTERNAL_CACHE_TTL=3600
EXTERNAL_MAX_PDFS=3
WEB_MAX_RESULTS=8

ARXIV_MAX_RESULTS=6
ARXIV_READ_PDF_COUNT=3
SEMANTIC_SCHOLAR_MAX=6
WIKIPEDIA_MAX=3
PATENT_MAX_RESULTS=4

ONLINE_PDF_MAX_PAGES=30
ONLINE_PDF_MAX_CHUNKS=12
ONLINE_PDF_CHUNK_CHARS=1600

GITHUB_MAX_REPOS=5
GITHUB_MAX_FILES=3
GITHUB_MAX_FILE_BYTES=60000
GITHUB_EXCERPT_LINES=120


# ==============================================================================
# 09. Autonomous Code Agent
# ==============================================================================

AGENT_MAX_ITERS=4
AGENT_GEN_MAX_TOKENS=5000
AGENT_REFLECT_MAX_TOKENS=2000

AGENT_DOCKER_IMAGE=python:3.11-slim
AGENT_RUN_TIMEOUT=30
AGENT_MEM_LIMIT=512m
AGENT_CPUS=1.0
AGENT_PIDS_LIMIT=128

AGENT_BRIEF_MAX_CHARS=3000
AGENT_LOG_MAX_CHARS=2000
AGENT_LOG_KEEP_LAST=12

AGENT_AUDIT_LOG=data/logs/agent_audit.jsonl
AGENT_BLOCK_PATTERNS=
AGENT_PRERUN_HOOK=

# Deep-research orchestration engine: "builtin" (default) or "langgraph".
# langgraph runs the same plan/search/synthesize/reflect/report pipeline as an
# explicit LangGraph state machine (pip install langgraph). Falls back to builtin
# if the package is missing.
# RESEARCH_ENGINE=langgraph


# ==============================================================================
# 10. Optional Memgraph GraphRAG
# ==============================================================================

ENABLE_GRAPH_RAG=false
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=
MEMGRAPH_DATABASE=
GRAPH_RAG_MAX_HOPS=2
GRAPH_RAG_MAX_RESULTS=12
GRAPH_RAG_TIMEOUT_SECONDS=3
GRAPH_RAG_BUILD_BATCH_SIZE=200


# ==============================================================================
# 11. Device / Local Model Runtime
# ==============================================================================

# auto | cuda | cpu | cuda:0
DEVICE=auto
EMBEDDING_DEVICE=auto
RERANKER_DEVICE=auto


# ==============================================================================
# 12. PDF Ingestion / Chunking
# ==============================================================================

ENABLE_OCR=true
CHUNK_MAX_CHARS=1800
CHUNK_OVERLAP_SENTENCES=2
MIN_SENTENCE_CHARS=10
MIN_CHUNK_CHARS=150
EMBED_DB_BATCH=16

# Optional vector index during migration.
CREATE_VECTOR_INDEX=false


# ==============================================================================
# 13. Local Retrieval Advanced Knobs
# ==============================================================================

RRF_K=60
MMR_LAMBDA=0.7
ENABLE_HYDE=true


# ==============================================================================
# 14. Public Tunnel / Sharing
# ==============================================================================

# Used only if your run.py share workflow is enabled.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_HOSTNAME=
