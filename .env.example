# ======================================================================
# Audio Research Assistant - environment configuration TEMPLATE
# Copy to ".env" and fill in your own values:   cp .env.example .env
# The real .env is gitignored and must never be committed.
# ======================================================================

# --- Oracle vector database ---
ORACLE_USER=AUDIO_RAG
ORACLE_PASSWORD=change_me
ORACLE_DSN=localhost:1521/FREEPDB1

# --- LLM provider selection (ollama | openai | anthropic) ---
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b-instruct

# --- API keys (leave blank for providers you don't use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- OpenAI models ---
OPENAI_MODEL=gpt-4-turbo
OPENAI_REASONING_EFFORT=high
OPENAI_DEEP_MODEL=gpt-5.5-pro

# --- Anthropic models ---
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_THINKING_BUDGET=8000
ANTHROPIC_DEEP_MODEL=claude-opus-4-7

# --- Embedding & re-ranking models ---
# EMBEDDING_PROVIDER: google (Gemini API) or local (sentence-transformers)
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-2          # local example: BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3        # reranker stays local
EMBEDDING_DIM=768
# Free Gemini API key for embeddings: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Compute device (GPU / CPU) ---
# DEVICE: auto (GPU if available, else CPU) | cuda | cpu
# Per-model overrides let you use BOTH GPU and CPU on a small GPU:
#   embeddings on GPU, the heavier reranker on CPU.
DEVICE=auto
EMBEDDING_DEVICE=cuda
RERANKER_DEVICE=cpu

# --- Answer engine ---
ANSWER_PROVIDER=manual
APP_MODE=balanced
AUTO_INGEST=true
DEBUG_MODE=false

# --- Retrieval tuning ---
MAX_QUERY_ROUTES=4
RETRIEVAL_TOP_K=8
TOTAL_SOURCE_LIMIT=14
PER_TOPIC_SOURCE_LIMIT=3

# --- HuggingFace / tokenizer noise suppression ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_DISABLE_PROGRESS_BARS=1
HF_HUB_DISABLE_TELEMETRY=1
TRANSFORMERS_VERBOSITY=error
TOKENIZERS_PARALLELISM=false

# --- PDF parsing / ingestion ---
PARSER_MODE=auto
ENABLE_DOCLING=true
ENABLE_MARKER=false
ENABLE_OCR=true
ENABLE_TABLE_EXTRACTION=true
ENABLE_EQUATION_CHUNKING=true
CHUNK_MAX_CHARS=1800
CHUNK_OVERLAP_SENTENCES=2
